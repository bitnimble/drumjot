{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "$APPDATA/outputs/**" }]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "$TEMP/drumjot/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$TEMP/drumjot" }, { "path": "$TEMP/drumjot/**" }]
    }
  ]
}
