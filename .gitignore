.claude/settings.local.json

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# TypeScript v1 declaration files
typings/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test

# parcel-bundler cache (https://parceljs.org/)
.cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
# Comment in the public line in if your project uses Gatsby and *not* Next.js
# https://nextjs.org/blog/next-9-1#public-directory-support
# public

# vuepress build output
.vuepress/dist

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Transcriber service (Python backend, see transcriber/). Service-specific
# paths only; generic Python artifacts (venv / egg-info / caches) are ignored
# globally below so they're covered for every subproject (transcriber,
# training/, dsp/), not just this one.
transcriber/.env
transcriber/data
transcriber/models
transcriber/debug
transcriber/build

# Python tooling (general). Listed globally, the repo has three Python
# subprojects (transcriber, training/, dsp/), each with its own venv +
# editable-install egg-info, plus any `python` run from the repo root leaks
# caches here.
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# kuromoji dictionary, copied from node_modules into public/ by
# scripts/copy-kuromoji-dict.mjs (postinstall). Lazy-fetched at runtime
# for Japanese lyrics; a few MB of generated assets, not source.
frontend/public/kuromoji-dict/

# Storybook static build output (`bun run build-storybook`).
storybook-static/

# Scratch report written by the /overnight skill (uncommitted morning log).
OVERNIGHT_LOG.md

# OS noise
.DS_Store
Thumbs.db

# Editor / IDE local settings (per-user). Add explicit shared configs
# back with `git add -f` if you want to commit them.
.idea/
.cursor/
*.swp
*.swo
*~

# Bun caches (per-project / per-user)
.bun/

# Playwright e2e artifacts. Browser binaries live in the per-user
# ~/.cache/ms-playwright (not in-repo). These are the run outputs.
test-results/
playwright-report/
blob-report/
.playwright/
# Ad-hoc screenshots written by Playwright specs into `tests/` (e.g.
# `popover.screenshot({ path: 'tests/foo.png' })`). Kept local for
# eyeballing; not a snapshot baseline.
frontend/tests/*.png

# Scratch / experiment artifacts (training sweeps, ad-hoc scripts, JSONs).
# Kept local, never committed. `/tmp/` is the holding folder; `/tmp_*` is a
# safety net for tools that hardcode a repo-root output path (e.g. a running
# sweep's --out-json) so their files never surface as untracked. (Logs are
# already covered by `*.log` above.)
/tmp/
/tmp_*

# Brainstorming visual companion
.superpowers/
