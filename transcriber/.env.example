# Copy this file to `.env` (gitignored) and fill in the secret.

# Anthropic API key (required). https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model used by the filter stage (rejects artifact onsets per
# instrument before the kept onsets render to MIDI).
LLM_MODEL=claude-opus-4-7

# Max concurrent per-instrument filter LLM calls. Calls are small; this
# mainly guards API rate limits.
INSTRUMENT_CONCURRENCY=4

# Host ports the bundled image exposes. Container-internal ports are
# fixed (5173 = frontend SPA + /api proxy, 8001 = transcriber router);
# only the host side of each docker-compose mapping changes.
#
# These two vars are read by docker-compose for the `ports:` mappings,
# which means `env_file:` is NOT enough; to actually override the
# defaults you need to either set them in your shell, in the repo-root
# `.env`, or run compose with `--env-file transcriber/.env`.
#
# If you change TRANSCRIBER_PORT and run the Vite dev server against
# this stack (instead of the bundled frontend), also start it with
# `TRANSCRIBER_URL=http://localhost:<port> bun run dev`.
FRONTEND_PORT=5173
TRANSCRIBER_PORT=8001

# Set DISABLE_FRONTEND=1 to skip the in-container Caddy :5173 listener
# (the bundled SPA + /api proxy). Use when running the Vite dev server
# on the host so the dev server can claim :5173 itself. Pair this with a
# non-5173 FRONTEND_PORT (or commenting out the 5173 line in
# docker-compose.yml) so docker doesn't reserve host :5173 for the
# now-empty container port.
DISABLE_FRONTEND=0

# JSON-encoded list of allowed CORS origins. Vite dev server runs on 5173.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# `auto` lets audio-separator pick CUDA/MPS/CPU; force with `cuda` / `cpu`.
DEVICE=auto

# When set, every /transcribe request persists its intermediate files
# (input audio, drum stem, per-instrument stems, beats.json, onsets.json,
# prediction.mid, note_provenance.json) into a per-request subdir under
# this path. Leave blank to keep request data ephemeral. The
# docker-compose volume `./debug:/debug` already exposes /debug to the
# host, so the recommended value for local debugging is `/debug`.
#
# Per-request alternative: pass `debug=true` on /transcribe to opt-in
# without setting this globally; that falls back to /debug as the base.
DEBUG_DIR=
