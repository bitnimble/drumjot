# Copy this file to `.env` (gitignored) and fill in the secret.

# Anthropic API key (required). https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model used for first-pass transcription + refinement revisions.
LLM_MODEL=claude-opus-4-7

# Cheaper Claude model used by the refinement critic (issue triage). Set
# to an empty string to disable the critic and fall back to deterministic
# confidence ranking.
CRITIC_MODEL=claude-haiku-4-5-20251001

# Whether refinement runs by default when the UI doesn't explicitly say.
REFINE_BY_DEFAULT=true

# Whether the deterministic Jot linter runs by default. Independent of
# `REFINE_BY_DEFAULT` — you can run lint alone (cheap, deterministic
# instrument/performance fixes), refinement alone (F1-gated tempo /
# onset / velocity), or both.
LINT_BY_DEFAULT=true

# Best-of-K: candidate transcriptions generated + scored per instrument
# (transcription is per-instrument). K candidates per drum pitch, each
# scored on that pitch's onset F1, best kept. 1 = single-shot (cheapest);
# 3 is a reasonable accuracy/cost balance. Cost ≈ K × (#instruments)
# small LLM calls, run in parallel up to INSTRUMENT_CONCURRENCY.
BEST_OF_K_DEFAULT=1

# Max concurrent per-instrument LLM calls (transcribe + per-instrument
# refinement). Calls are small; this mainly guards API rate limits.
INSTRUMENT_CONCURRENCY=4

# Host port the transcriber service is exposed on. Only the host side of
# the docker-compose mapping changes — container-internal port stays 8001
# regardless. If you change this, also start the Vite dev server with
# `VITE_TRANSCRIBER_URL=http://localhost:<port> bun run dev` so the
# frontend proxy targets the new port.
TRANSCRIBER_PORT=8001

# JSON-encoded list of allowed CORS origins. Vite dev server runs on 5173.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# `auto` lets audio-separator pick CUDA/MPS/CPU; force with `cuda` / `cpu`.
DEVICE=auto

# When set, every /transcribe request persists its intermediate files
# (input audio, drum stem, per-instrument stems, beats.json, onsets.json,
# initial.jot, final.jot, refinement.json) into a per-request subdir
# under this path. Leave blank to keep request data ephemeral. The
# docker-compose volume `./debug:/debug` already exposes /debug to the
# host, so the recommended value for local debugging is `/debug`.
#
# Per-request alternative: pass `debug=true` on /transcribe to opt-in
# without setting this globally; that falls back to /debug as the base.
DEBUG_DIR=
