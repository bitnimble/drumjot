{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",

      "Bash(mcp__plugin_playwright_playwright_browser_navigate)",
      "Bash(mcp__plugin_playwright_playwright_browser_take_screenshot)",
      "Bash(mcp__plugin_playwright_playwright_browser_click)",
      "Bash(mcp__plugin_playwright_playwright_browser_evaluate)",

      "Bash(mcp__plugin_linear_linear)",

      "Bash(bun install)",
      "Bash(bun run build *)",
      "Bash(bun typecheck *)",
      "Bash(bun run typecheck *)",
      "Bash(bun lint:design *)",
      "Bash(bun run lint:design *)",
      "Bash(bun format *)",
      "Bash(bun run format *)",
      "Bash(bun add *)",
      "Bash(bun run test *)",
      "Bash(bun run e2e *)",
      "Bash(bun run e2e:run *)",
      "Bash(bun run e2e:perf *)",
      "Bash(bun run e2e:report *)",
      "Bash(bun run build-storybook *)",
      "Bash(bun run postinstall *)",

      "Bash(git status *)",
      "Bash(git add *)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(git show *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git commit *)",
      "Bash(git rebase *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(git reset *)",

      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(cut *)",
      "Bash(jq *)",
      "Bash(diff *)",
      "Bash(cmp *)",
      "Bash(ls *)",
      "Bash(stat *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(pwd *)"
    ],
    "deny": [
      "Bash(git push *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enabledMcpjsonServers": [
    "playwright"
  ]
}
