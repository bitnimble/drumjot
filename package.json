{
  "name": "drumjot",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "repository": "git@github.com:bitnimble/drumjot.git",
  "author": "D <me@kumo.dev>",
  "license": "MIT",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bun run lint:design && bunx tsc --noEmit && bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "typecheck": "bunx tsc --noEmit",
    "lint:design": "stylelint 'src/**/*.css'",
    "test": "bun test",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report --host 0.0.0.0"
  },
  "packageManager": "bun@1.3.5",
  "dependencies": {
    "classnames": "^2.5.1",
    "lucide-react": "^1.16.0",
    "midi-file": "^1.2.4",
    "mobx": "^6.13.5",
    "mobx-react-lite": "^4.0.7",
    "mobx-utils": "^6.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "smplr": "^0.21.0",
    "soundfont2": "^0.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "stylelint": "^17.12.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
