{
  "name": "drumjot",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "repository": "git@github.com:bitnimble/drumjot.git",
  "author": "D <me@kumo.dev>",
  "license": "MIT",
  "scripts": {
    "dev": "bunx vite",
    "build": "bun run lint:design && bunx tsc --noEmit && bunx vite build",
    "preview": "bunx vite preview",
    "typecheck": "bunx tsc --noEmit",
    "lint:design": "stylelint --fix 'frontend/src/**/*.css'",
    "test": "bun test",
    "e2e": "bun --env-file=.env run e2e:run",
    "e2e:run": "playwright test",
    "e2e:perf": "bun --env-file=.env run playwright test --project=perf --no-deps",
    "e2e:report": "playwright show-report --host 0.0.0.0",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "postinstall": "bun run scripts/copy-kuromoji-dict.mjs"
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@sglkc/kuromoji": "^1.1.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "classnames": "^2.5.1",
    "loro-crdt": "^1.13.2",
    "lucide-react": "^1.16.0",
    "midi-file": "^1.2.4",
    "mobx": "^6.13.5",
    "mobx-react-lite": "^4.0.7",
    "mobx-utils": "^6.1.0",
    "react": "^18.3.1",
    "react-colorful": "^5.7.0",
    "react-dom": "^18.3.1",
    "signalsmith-stretch": "^1.3.2",
    "smplr": "^0.21.0",
    "soundfont2": "^0.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@storybook/react-vite": "^9",
    "@tauri-apps/cli": "^2.11.4",
    "@types/bun": "^1.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "storybook": "^9",
    "stylelint": "^17.12.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-css-modules": "^1.16.0",
    "vite-plugin-wasm": "^3.6.0"
  },
  "browserslist": [
    "last 2 years",
    "not dead",
    "not op_mini all"
  ]
}
