#!/usr/bin/env bash
# scripts/check-ts [bun-test-args...]
#
# Frontend post-change checks: stylelint (with --fix) + tsc + bun test.
# Any args are passed through to `bun test`, so
# `scripts/check-ts src/recompose.test.ts` works for single-file iteration.
#
# Uses bun / bunx — never npm / npx (see AGENTS.md §3).

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$REPO"

echo "== stylelint --fix =="
bunx stylelint 'src/**/*.css' --fix

echo
echo "== tsc --noEmit =="
bunx tsc --noEmit

echo
echo "== bun test =="
bun test "$@"
