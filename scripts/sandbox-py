#!/usr/bin/env bash
# scripts/sandbox-py '<python code>' [argv...]
#
# Run a Python snippet inside the drumjot sandbox container, like
# `python3 -c "..."`. Any extra args after the code become sys.argv[1:].
#
#   scripts/sandbox-py 'import torch; print(torch.cuda.is_available())'
#   scripts/sandbox-py 'import sys; print(sys.argv[1:])' foo bar
#
# Reads code from stdin if no argument is given:
#   scripts/sandbox-py < some_script.py
#
# The container runs as UID 1000 with /codebox-workspace mounted, so the
# snippet can read prior transcribe output and write scratch to /sandbox.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ $# -ge 1 ]; then
    code=$1
    shift
else
    code=$(cat)
fi

exec "$SCRIPT_DIR/sandbox-run" python3 -c "$code" "$@"
