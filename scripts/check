#!/usr/bin/env bash
# scripts/check — post-change checks for both sides of the repo.
#
# Runs every check an agent should perform after touching code:
# ruff (Python, autofix), pytest, stylelint (CSS, autofix), tsc, bun test.
# Exits non-zero on the first failure.
#
# Prefer this over invoking ruff / pytest / tsc / bun test / stylelint
# directly — it gets the venv activation, working directory, and autofix
# flags right so the agent doesn't have to re-derive them every time.
#
# Scoped variants: `scripts/check-py [pytest args]`, `scripts/check-ts
# [bun test args]`. Use those for fast iteration in one side of the repo.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

"$SCRIPT_DIR/check-py"
"$SCRIPT_DIR/check-ts"
